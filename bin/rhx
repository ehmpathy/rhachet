#!/bin/sh
# .what = proxy that prepends `run --skill` and delegates to rhachet
# .why = shorthand for `rhachet run --skill`
#
# .note = keyrack is short-circuited to avoid skill proxy overhead

# follow symlinks to find the real bin directory (handles pnpm hoisted mode)
# .note = POSIX shell has no const/immutable constructs; mutation is the only mechanism
#         for loops. this is the standard idiom used by git, docker, and all major shell projects.
EXECUTABLE="$0"
LINK_DEPTH=0
while [ -L "$EXECUTABLE" ]; do
  LINK_DEPTH=$((LINK_DEPTH + 1))
  if [ "$LINK_DEPTH" -gt 20 ]; then
    echo "error: symlink cycle detected after 20 iterations" >&2
    exit 1
  fi
  SCRIPT_DIR="$(cd "$(dirname "$EXECUTABLE")" && pwd)"
  EXECUTABLE="$(readlink "$EXECUTABLE")"
  case "$EXECUTABLE" in
    /*) ;;
    *) EXECUTABLE="$SCRIPT_DIR/$EXECUTABLE" ;;
  esac
done
SCRIPT_DIR="$(cd "$(dirname "$EXECUTABLE")" && pwd)"

# short-circuit keyrack commands (via jit path, not bun binary)
if [ "$1" = "keyrack" ]; then
  shift
  exec "$SCRIPT_DIR/run.jit" keyrack "$@"
fi

# short-circuit upgrade command (top-level rhachet command, not a skill)
if [ "$1" = "upgrade" ]; then
  shift
  exec "$SCRIPT_DIR/run.jit" upgrade "$@"
fi

# short-circuit enroll command (top-level rhachet command, not a skill)
if [ "$1" = "enroll" ]; then
  shift
  exec "$SCRIPT_DIR/run" enroll "$@"
fi

# default: proxy to run --skill
exec "$SCRIPT_DIR/run" run --skill "$@"
