#!/bin/sh
######################################################################
# .what = shell entrypoint for rhachet CLI
# .why = routes to bun (fast) or jit (flexible) dispatcher
#
# architecture:
#   run, roles boot/cost → run.bun (bun compiled, reads .agent/)
#   *                    → run.jit (jit, imports from npm packages)
#
# .note = run.bun does finer-grained dispatch to .bc binaries
######################################################################

# resolve script directory (handles symlinks from node_modules/.bin/)
# .note = POSIX shell has no const/immutable constructs; mutation is the only mechanism
#         for loops. this is the standard idiom used by git, docker, and all major shell projects.
SCRIPT="$0"
LINK_DEPTH=0
while [ -L "$SCRIPT" ]; do
  LINK_DEPTH=$((LINK_DEPTH + 1))
  if [ "$LINK_DEPTH" -gt 20 ]; then
    echo "error: symlink cycle detected after 20 iterations" >&2
    exit 1
  fi
  SCRIPT_DIR="$(cd "$(dirname "$SCRIPT")" && pwd)"
  SCRIPT="$(readlink "$SCRIPT")"
  case "$SCRIPT" in
    /*) ;;
    *) SCRIPT="$SCRIPT_DIR/$SCRIPT" ;;
  esac
done
SCRIPT_DIR="$(cd "$(dirname "$SCRIPT")" && pwd)"

case "$1" in
  run)
    # fast path: dispatch to bun, if allowlisted
    exec "$SCRIPT_DIR/run.bun" "$@"
    ;;
  roles)
    case "$2" in
      boot|cost)
        # fast path: dispatch to bun, if allowlisted
        exec "$SCRIPT_DIR/run.bun" "$@"
        ;;
      *)
        # else, use jit
        exec "$SCRIPT_DIR/run.jit" "$@"
        ;;
    esac
    ;;
  *)
    # else, use jit
    exec "$SCRIPT_DIR/run.jit" "$@"
    ;;
esac
