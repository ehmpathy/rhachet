   └─ testorg.test.__TEST_OUTPUT_GRANTED__
      ├─ vault: os.envvar
      ├─ mech: PERMANENT_VIA_REPLICA
      └─ status: granted 🔑

"
`;

exports[`keyrack get --output modes given: [case1] key granted via env passthrough when: [t5] --value piped to variable has no extra whitespace then: stdout matches snapshot 1`] = `"test-secret-value-123"`;

