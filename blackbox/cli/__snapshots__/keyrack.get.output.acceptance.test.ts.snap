      "grade": {
        "protection": "plaintext",
        "duration": "permanent"
      }
    },
    "source": {
      "vault": "os.envvar",
      "mech": "PERMANENT_VIA_REPLICA"
    },
    "env": "test",
    "org": "testorg"
  }
}
"
`;

exports[`keyrack get --output modes given: [case1] key granted via env passthrough when: [t3] --output vibes outputs treestruct then: stdout matches snapshot 1`] = `
