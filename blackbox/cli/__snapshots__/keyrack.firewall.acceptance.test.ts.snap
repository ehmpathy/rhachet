// Jest Snapshot v1, https://jestjs.io/docs/snapshot-testing

exports[`keyrack firewall given: [case1] keyrack firewall command when: [t-help] firewall --help then: stdout matches snapshot 1`] = `
"Usage: rhachet keyrack firewall [options]

translate and validate secrets for CI environments

Options:
  --env <env>      which env to grant (test, prod, prep, all)
  --from <source>  input source slug (e.g., json(env://SECRETS),
                   json(stdin://*))
  --into <format>  output format (github.actions, json)
  --owner <owner>  keyrack owner (default: "default")
  -h, --help       display help for command
"
`;

exports[`keyrack firewall given: [case1] keyrack firewall command when: [t0] firewall with safe key (json output) then: stdout matches snapshot 1`] = `
"[
  {
    "status": "granted",
    "grant": {
      "slug": "testorg.test.SAFE_API_KEY",
      "key": {
        "secret": "sk-safe-api-key-abc123",
        "grade": {
          "protection": "plaintext",
          "duration": "permanent"
        }
      },
      "source": {
        "vault": "os.envvar",
        "mech": "PERMANENT_VIA_REPLICA"
      },
      "env": "test",
      "org": "testorg"
    }
  },
  {
    "status": "locked",
    "slug": "testorg.test.GHP_TOKEN",
    "message": "credential 'testorg.test.GHP_TOKEN' is locked. unlock it first.",
    "fix": "rhx keyrack unlock --env test --key GHP_TOKEN"
  },
  {
    "status": "locked",
    "slug": "testorg.test.AKIA_TOKEN",
    "message": "credential 'testorg.test.AKIA_TOKEN' is locked. unlock it first.",
    "fix": "rhx keyrack unlock --env test --key AKIA_TOKEN"
  }
]
"
`;

exports[`keyrack firewall given: [case1] keyrack firewall command when: [t1] firewall with blocked key (ghp_*) then: stdout matches snapshot 1`] = `
"[
  {
    "status": "granted",
    "grant": {
      "slug": "testorg.test.SAFE_API_KEY",
      "key": {
        "secret": "sk-safe-api-key-abc123",
        "grade": {
          "protection": "plaintext",
          "duration": "permanent"
        }
      },
      "source": {
        "vault": "os.envvar",
        "mech": "PERMANENT_VIA_REPLICA"
      },
      "env": "test",
      "org": "testorg"
    }
  },
  {
    "status": "blocked",
    "slug": "testorg.test.GHP_TOKEN",
    "reasons": [
      "its dangerous to use long lived tokens via replica mechanisms",
      "detected github classic pat (ghp_*)"
    ],
    "fix": "update the stored value to use a short-lived or properly-formatted credential"
  },
  {
    "status": "blocked",
    "slug": "testorg.test.AKIA_TOKEN",
    "reasons": [
      "its dangerous to use long lived tokens via replica mechanisms",
      "detected aws long-lived access key (AKIA*)"
    ],
    "fix": "update the stored value to use a short-lived or properly-formatted credential"
  }
]
"
`;

