      │  └─ status: granted 🔑
      ├─ GHP_TOKEN
      │  ├─ status: blocked 🚫
      │  └─ reasons: its dangerous to use long lived tokens via replica mechanisms, detected github classic pat (ghp_*)

"
`;

exports[`keyrack firewall given: [case1] keyrack firewall command when: [t9] firewall with invalid --into format then: stderr matches snapshot 1`] = `
"
BadRequestError: invalid --into value

{
  "into": "invalid-format",
  "valid": [
    "github.actions",
    "json"
  ]
}

[args] keyrack,firewall,--env,test,--from,json(env://SECRETS_JSON),--into,invalid-format

"
`;

exports[`keyrack firewall given: [case1] keyrack firewall command when: [t10] firewall with malformed SECRETS_JSON then: stderr matches snapshot 1`] = `
"
BadRequestError: malformed secrets JSON

{
  "source": {
    "type": "env",
    "format": "json",
    "envVar": "SECRETS_JSON"
  },
  "hint": "ensure the input is valid JSON object"
}

[args] keyrack,firewall,--env,test,--from,json(env://SECRETS_JSON),--into,json

"
`;

exports[`keyrack firewall given: [case1] keyrack firewall command when: [t11] firewall with SECRETS_JSON env var not set then: stderr matches snapshot 1`] = `
"
BadRequestError: env var not set

{
  "envVar": "SECRETS_JSON",
  "hint": "set SECRETS_JSON or use --from 'json(stdin://*)'"
}

[args] keyrack,firewall,--env,test,--from,json(env://SECRETS_JSON),--into,json

"
`;

exports[`keyrack firewall given: [case1] keyrack firewall command when: [t12] firewall github.actions output requires GITHUB_ENV then: stderr matches snapshot 1`] = `
"
✋ ConstraintError: GITHUB_ENV not set

{
  "hint": "--into github.actions requires a GitHub Actions workflow context"
}

[args] keyrack,firewall,--env,test,--from,json(env://SECRETS_JSON),--into,github.actions

"
`;

exports[`keyrack firewall given: [case1] keyrack firewall command when: [t13] firewall with multiline secret value then: stdout matches snapshot 1`] = `
"
🔐 keyrack firewall
   ├─ grants: 1
   └─ keys
      ├─ SAFE_API_KEY
      │  ├─ mech: PERMANENT_VIA_REPLICA
      │  └─ status: granted 🔑

::add-mask::-----BEGIN RSA PRIVATE KEY-----
::add-mask::MIIE...test...
::add-mask::line2
::add-mask::-----END RSA PRIVATE KEY-----
"
`;
