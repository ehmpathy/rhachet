exports[`keyrack firewall given: [case1] keyrack firewall command when: [t8] firewall with blocked key (github.actions output) then: stdout matches snapshot 1`] = `
"
🔐 keyrack firewall
   ├─ grants: 0
   ├─ blocked: 1
   └─ keys
      ├─ SAFE_API_KEY
