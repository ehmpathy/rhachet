exports[`keyrack vault aws.config given: [case13] guided setup with mock aws CLI when: [t0] keyrack set --vault aws.config via guided wizard (pseudo-TTY) then: stdout matches snapshot 1`] = `
"рџ”ђ keyrack set AWS_PROFILE
   в”‚
   в”њв”Ђ which sso domain?
   в”‚  в”њв”Ђ options
   в”‚  в”‚  в””в”Ђ 1. https://d-12345abcde.awsapps.com/start, testorg, us-east-1
   в”‚  в””в”Ђ choice
   в”‚     в””в”Ђ 1
   в”‚     в”њв”Ђ 1 вњ“
   в”‚     в””в”Ђ as https://d-12345abcde.awsapps.com/start, testorg
   в”‚
   в”њв”Ђ with sso prior?
   в”‚  в””в”Ђ вњ“ clear, no prior session
   в”‚
   в”њв”Ђ which sso login?
   в”‚  в”њв”Ђ authorize in browser
   в”‚  в”‚  в”њв”Ђ рџ”— https://device.sso.us-east-1.amazonaws.com/
   в”‚  в”‚  в””в”Ђ рџ”‘ MOCK-CODE
   в”‚  в””в”Ђ вњ“ authenticated
   в”‚
   в”њв”Ђ which account?
   в”‚  в”њв”Ђ options
   в”‚  в”‚  в”њв”Ђ 1. testorg-dev   123456789012
   в”‚  в”‚  в””в”Ђ 2. testorg-prod  987654321098
   в”‚  в””в”Ђ choice
   в”‚     в””в”Ђ 1
   в”‚     в”њв”Ђ 1 вњ“
   в”‚     в””в”Ђ as testorg-dev
   в”‚
   в”њв”Ђ which role?
   в”‚  в”њв”Ђ options
   в”‚  в”‚  в”њв”Ђ 1. AdministratorAccess
   в”‚  в”‚  в””в”Ђ 2. ReadOnlyAccess
   в”‚  в””в”Ђ choice
   в”‚     в””в”Ђ 1
   в”‚     в”њв”Ђ 1 вњ“
   в”‚     в””в”Ђ as AdministratorAccess
   в”‚
   в”њв”Ђ what should we call it?
   в”‚  в”њв”Ђ suggested
   в”‚  в”‚  в””в”Ђ testorg.dev
   в”‚  в””в”Ђ choice
   в”‚     в””в”Ђ
   в”‚     в”њв”Ђ вњ“
   в”‚     в””в”Ђ as testorg.dev
   в”‚
   в”њв”Ђ lovely, lets vault it now...
   в”‚  в””в”Ђ вњ“ written to ~/.aws/config
   в”‚
   в””в”Ђ perfect, now lets verify...
      в”њв”Ђ вњ“ unlock
      в”њв”Ђ вњ“ get
      в””в”Ђ вњ“ relock

рџ”ђ keyrack set (org: testorg, env: test)
   в””в”Ђ testorg.test.AWS_PROFILE
      в”њв”Ђ mech: EPHEMERAL_VIA_AWS_SSO
      в””в”Ђ vault: aws.config"
`;

